{
  "identifier": "default",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": ["http://localhost:1420/*", "http://localhost:14200/*"]
  },
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "dialog:default",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta-recursive",
    "updater:default"
  ]
}